# 3D assets are binary (no text diff/merge).
# NOTE: committed directly to Git for now. To move them into Git LFS later:
#   sudo apt install git-lfs && git lfs install
#   git lfs migrate import --include="*.dae,*.step,*.stl,*.stp,*.obj"
*.dae  binary
*.stl  binary
*.step binary
*.stp  binary
*.obj  binary

# Normalize line endings for text sources.
*.py    text eol=lf
*.xacro text eol=lf
*.world text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
